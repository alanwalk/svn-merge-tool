{
    "name": "svn-merge-tool",
    "version": "1.1.0-beta",
    "description": "SVN branch merge CLI tool - merge specific revisions one by one",
    "license": "MIT",
    "homepage": "https://github.com/alanwalk/svn-merge-tool#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alanwalk/svn-merge-tool.git"
    },
    "bugs": {
        "url": "https://github.com/alanwalk/svn-merge-tool/issues"
    },
    "bin": {
        "svnmerge": "bin/svnmerge.js"
    },
    "files": [
        "bin/",
        "dist/",
        "README.md",
        "README.zh-CN.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "start": "ts-node src/index.ts",
        "build": "tsc && node scripts/copy-ui-assets.js",
        "lint": "tsc --noEmit",
        "prepublishOnly": "npm run lint && npm run build",
        "test": "node --require ./test/register.cjs --test test/utils.test.ts test/config.test.ts test/svn.test.ts test/merger.test.ts test/message.test.ts"
    },
    "dependencies": {
        "commander": "^12.1.0",
        "js-yaml": "^4.1.1"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.0"
    }
}
